# Database
DATABASE_URL=postgresql://clawdashboard:clawdashboard@postgres:5432/clawdashboard

# App
NODE_ENV=production
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_PASSWORD=change-me

# Public URL (used for OpenClaw webhook callbacks)
APP_URL=http://localhost:3000

# OpenClaw Gateway (internal Docker network)
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789
OPENCLAW_HOOKS_TOKEN=change-me-hooks-token
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token
OPENCLAW_WEBHOOK_SECRET=change-me-webhook-secret

# Worker
WORKER_ENABLED=true

# Optional: Docker socket for cron CLI bridge (Coolify sidecar pattern)
DOCKER_HOST=unix:///var/run/docker.sock
OPENCLAW_GATEWAY_CONTAINER=openclaw-gateway
